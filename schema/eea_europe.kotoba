// Eea_europe clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace eea_europe {

    entity Application {
        id: string @unique
        applicantId: string
        type: string
        number: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Grant {
        id: string @unique
        applicationId: string
        number: string
        grantedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Surveillance {
        id: string @unique
        disease: string
        region: string
        cases: integer
        reportedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Measurement {
        id: string @unique
        station: string
        parameter: string
        value: float
        measuredAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Patent {
        id: string @unique
        applicantId: string
        title: string
        number: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Trial {
        id: string @unique
        sponsor: string
        phase: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
